# Server Configuration
PORT=5000
NODE_ENV=development
HOST=0.0.0.0

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=server_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key

SUPABASE_BUCKET_NAME=grampanchayat-files

# Database Configuration (PostgreSQL connection string from Supabase)
# Get from: Supabase Dashboard → Settings → Database → Connection String (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT Secret (Generate strong secret for production)
# Generate at: https://randomkeygen.com/ or use: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# CORS Origins (comma separated, no spaces)
# For local development:
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# For production (update after deploying frontends):
# CORS_ORIGINS=https://your-admin.vercel.app,https://your-website.vercel.app

# File Upload Settings
MAX_FILE_SIZE=10485760

# =====================================================
# AUTO-SETUP CONFIGURATION
# These values are used for automatic database setup
# =====================================================

# Default Admin User (Created automatically on first startup)
ADMIN_EMAIL=admin@grampanchayat.gov.in
ADMIN_PASSWORD=admin123
# ⚠️ IMPORTANT: Change password after first login!

# =====================================================
# DEPLOYMENT INSTRUCTIONS
# =====================================================
# 1. Copy this file to .env
# 2. Update Supabase credentials
# 3. Update DATABASE_URL with your Supabase connection string
# 4. Update ADMIN_EMAIL and ADMIN_PASSWORD
# 5. Deploy to Render
# 6. Tables and admin will be created automatically!
# 7. Login to admin panel and add Grampanchayat info in Task 7
# =====================================================
